/* 
Problem:
-> Given a sorted array( it may have some dublicates ) and return number of unique element in the array.
Logic:
-> Put a pointer on start of the array 
-> Traverse a pointer on the array & until we get different element then 1st element in the array increment it.
-> When we got different one place it exact next to the starting one. 
Time Complexity:
-> O(N)
Space Complexity:
-> O(1)
Solution:
*/
#include<iostream>
using namespace std;
int unique_element_count(int array[],int size){
	int i=0;
	for(int j=0;j<size;j++){
		if(array[i]!=array[j]){
			array[i+1]=array[j];
			i++;
		}
	}
	return i+1;
}
int main(){
	int n;
	cout<<"Enter the value of n: "<<endl; 
	cin>>n;
    int arr[n];
    cout<<"Enter the element of the array: "<<endl;
    for(int i=0;i<n;i++){
    	cin>>arr[i];
	}
	int Unique_element_Num=unique_element_count(arr,n);
	cout<<"No. of unique element in the array is: "<<Unique_element_Num<<endl;
	return 0;
}
